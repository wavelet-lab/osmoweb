{
    "name": "osmoweb",
    "description": "OsmoWeb package",
    "author": "Timur Davydov <dtv.comp@gmail.com>",
    "license": "MIT",
    "keywords": [
        "osmoweb",
        "osmo",
        "osmocom",
        "libosmocom",
        "2g",
        "gsm",
        "sms",
        "phone",
        "communication",
        "basestation",
        "network",
        "cellular",
        "telecommunications",
        "infrastructure",
        "radio",
        "websdr",
        "webusb",
        "wsdr",
        "wavelet"
    ],
    "private": true,
    "type": "module",
    "workspaces": [
        "./packages/core",
        "./packages/backend-core",
        "./packages/nestjs-microservice",
        "./packages/frontend-core",
        "./packages/vue3-components"
    ],
    "scripts": {
        "build": "npm run build --workspaces",
        "docs:diagrams": "node scripts/render-mermaid.js docs",
        "docs:diagrams:ubuntu": "MMD_AAEXEC=1 node scripts/render-mermaid.js docs",
        "test": "npm run test --workspaces",
        "test:all": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui"
    },
    "devDependencies": {
        "@mermaid-js/mermaid-cli": "^11.15.0",
        "@types/node": "^25.9.1",
        "@vitest/coverage-v8": "^4.1.7",
        "tsc-alias": "^1.8.17",
        "tsc-esm-fix": "^3.1.2",
        "typescript": "^6.0.3",
        "vite": "^8.0.14",
        "vitest": "^4.1.7"
    }
}
