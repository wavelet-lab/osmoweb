{
    "name": "@osmoweb/nestjs-microservice",
    "version": "0.6.3",
    "description": "This is a NestJS microservice for OsmoWeb",
    "author": "Timur Davydov <dtv.comp@gmail.com>",
    "license": "MIT",
    "keywords": [
        "nestjs",
        "microservice",
        "osmo",
        "websocket"
    ],
    "publishConfig": {
        "access": "public"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "scripts": {
        "build": "tsc && tsc-alias && tsc-esm-fix",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "prepack": "cp ../../LICENSE ./LICENSE || true",
        "postpack": "rm -f ./LICENSE"
    },
    "dependencies": {
        "@osmoweb/backend-core": "^0.6.3",
        "@osmoweb/core": "^0.6.3",
        "@websdr/nestjs-microservice": "^0.6.1",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "passport-jwt": "^4.0.1",
        "ws": "^8.21.0"
    },
    "devDependencies": {
        "@nestjs/testing": "^11.1.24",
        "@types/node": "^25.6.0",
        "@types/passport-jwt": "^4.0.1",
        "@types/ws": "^8.18.1"
    },
    "peerDependencies": {
        "@nestjs/common": "^11.1.24",
        "@nestjs/config": "^4.0.4",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/microservices": "^11.1.24",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/websockets": "^11.1.24"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./osmo": {
            "types": "./dist/osmo/index.d.ts",
            "import": "./dist/osmo/index.js",
            "require": "./dist/osmo/index.js"
        }
    },
    "files": [
        "dist",
        "!dist/tests",
        "LICENSE",
        "README.md"
    ]
}
