{
    "name": "@osmoweb/core",
    "version": "1.0.0",
    "description": "This is the core package for OsmoWeb",
    "author": "Timur <dtv.comp@gmail.com>",
    "license": "MIT",
    "keywords": [],
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "scripts": {
        "build": "tsc && tsc-alias && tsc-esm-fix",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "devDependencies": {
        "@types/node": "^24.2.1"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./osmo": {
            "types": "./dist/osmo/index.d.ts",
            "import": "./dist/osmo/index.js",
            "require": "./dist/osmo/index.js"
        },
        "./radio": {
            "types": "./dist/radio/index.d.ts",
            "import": "./dist/radio/index.js",
            "require": "./dist/radio/index.js"
        },
        "./utils": {
            "types": "./dist/utils/index.d.ts",
            "import": "./dist/utils/index.js",
            "require": "./dist/utils/index.js"
        }
    }
}