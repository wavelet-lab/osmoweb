{
    "name": "@osmoweb/core",
    "version": "0.6.2",
    "description": "This is the core package for OsmoWeb",
    "author": "Timur Davydov <dtv.comp@gmail.com>",
    "license": "MIT",
    "keywords": [
        "osmo",
        "frequency",
        "arfcn",
        "band",
        "technology",
        "GSM",
        "UMTS",
        "LTE",
        "NR"
    ],
    "publishConfig": {
        "access": "public"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "scripts": {
        "build": "tsc && tsc-alias && tsc-esm-fix",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "prepack": "cp ../../LICENSE ./LICENSE || true",
        "postpack": "rm -f ./LICENSE"
    },
    "dependencies": {
        "@websdr/core": "^0.6.0"
    },
    "devDependencies": {
        "@types/node": "^25.6.0"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./osmo": {
            "types": "./dist/osmo/index.d.ts",
            "import": "./dist/osmo/index.js",
            "require": "./dist/osmo/index.js"
        },
        "./radio": {
            "types": "./dist/radio/index.d.ts",
            "import": "./dist/radio/index.js",
            "require": "./dist/radio/index.js"
        }
    },
    "files": [
        "dist",
        "!dist/tests",
        "LICENSE",
        "README.md"
    ]
}
