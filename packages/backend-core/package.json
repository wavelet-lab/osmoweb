{
    "name": "@osmoweb/backend-core",
    "version": "0.6.2",
    "description": "This is the core backend package for OsmoWeb",
    "author": "Timur Davydov <dtv.comp@gmail.com>",
    "license": "MIT",
    "keywords": [
        "backend",
        "osmo",
        "websocket"
    ],
    "publishConfig": {
        "access": "public"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "scripts": {
        "build": "tsc && tsc-alias && tsc-esm-fix",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "prepack": "cp ../../LICENSE ./LICENSE || true",
        "postpack": "rm -f ./LICENSE"
    },
    "dependencies": {
        "@osmoweb/core": "^0.6.2",
        "@websdr/core": "^0.6.0",
        "ws": "^8.21.0"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "@types/ws": "^8.18.1"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./osmo": {
            "types": "./dist/osmo/index.d.ts",
            "import": "./dist/osmo/index.js",
            "require": "./dist/osmo/index.js"
        },
        "./osmoctrl": {
            "types": "./dist/osmoctrl/index.d.ts",
            "import": "./dist/osmoctrl/index.js",
            "require": "./dist/osmoctrl/index.js"
        },
        "./osmorouter": {
            "types": "./dist/osmorouter/index.d.ts",
            "import": "./dist/osmorouter/index.js",
            "require": "./dist/osmorouter/index.js"
        },
        "./osmorouter/protocol": {
            "types": "./dist/osmorouter/protocol/index.d.ts",
            "import": "./dist/osmorouter/protocol/index.js",
            "require": "./dist/osmorouter/protocol/index.js"
        },
        "./osmostats": {
            "types": "./dist/osmostats/index.d.ts",
            "import": "./dist/osmostats/index.js",
            "require": "./dist/osmostats/index.js"
        }
    },
    "files": [
        "dist",
        "!dist/tests",
        "LICENSE",
        "README.md"
    ]
}
